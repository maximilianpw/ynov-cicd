{
  "plugins": ["node_modules/jsdoc-babel"],
  "babel": {
    "extensions": ["js", "jsx", "mjs", "ts", "tsx"],
    "babelrc": false,
    "presets": [
      ["@babel/preset-typescript", { "isTSX": true, "allExtensions": true }],
      ["@babel/preset-react", { "runtime": "automatic" }]
    ]
  },
  "source": {
    "include": ["module.js", "src"],
    "includePattern": ".+\\.(js|jsx|mjs|ts|tsx)$",
    "exclude": ["node_modules", "dist", "coverage", "src/components/ui"],
    "excludePattern": "(^|/)(dist|coverage|node_modules)/|\\.test\\.(js|ts|tsx)$|routeTree\\.gen\\.ts$|setupTests\\.ts$|src/components/ui/"
  },
  "opts": {
    "destination": "dist/client/docs",
    "readme": "README.md",
    "recurse": true
  }
}
