services:
  registry:
    image: registry:2
    restart: unless-stopped
    environment:
      REGISTRY_STORAGE_DELETE_ENABLED: "true"
    expose:
      - "5000"
    volumes:
      - ./data:/var/lib/registry
    networks:
      - registry-net

  ui:
    image: joxit/docker-registry-ui:latest
    restart: unless-stopped
    environment:
      SINGLE_REGISTRY: "true"
      REGISTRY_TITLE: "Private Docker Registry"
      REGISTRY_URL: "https://{{ public_ip }}:443"
      DELETE_IMAGES: "true"
      SHOW_CONTENT_DIGEST: "true"
    expose:
      - "80"
    depends_on:
      - registry
    networks:
      - registry-net

  nginx:
    image: nginx:alpine
    restart: unless-stopped
    ports:
      - "443:443"
    volumes:
      - ./auth:/etc/nginx/auth:ro
      - ./nginx/nginx.conf:/etc/nginx/conf.d/default.conf:ro
      - ./certs:/etc/nginx/certs:ro
    depends_on:
      - registry
      - ui
    networks:
      - registry-net

networks:
  registry-net:
    driver: bridge
