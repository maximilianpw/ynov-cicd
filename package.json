{
  "name": "ynov-cicd",
  "version": "0.1.2",
  "description": "ynov-cicd",
  "private": false,
  "type": "module",
  "main": "./module.js",
  "exports": {
    ".": "./module.js"
  },
  "files": [
    "module.js",
    "README.md"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.28.0",
  "imports": {
    "#/*": "./src/*"
  },
  "homepage": "https://maximilianpw.github.io/ynov-cicd",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "build-npm-ci": "rm -rf dist && mkdir dist && NODE_ENV=production pnpm exec babel src --out-dir dist --copy-files",
    "build-npm": "pnpm run build-npm-ci",
    "postbuild": "cp dist/client/index.html dist/client/404.html",
    "preview": "vite preview",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint",
    "docs": "jsdoc -c jsdoc.json",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "predeploy": "pnpm run build && pnpm run docs",
    "deploy": "gh-pages -d dist/client"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "^1.167.65",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "gh-deploy": "^0.2.3",
    "gh-pages": "^6.3.0",
    "lucide-react": "^0.545.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.0",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.0",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/eslint-config": "latest",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-istanbul": "^4.1.5",
    "eslint": "^9.20.0",
    "jsdoc": "^4.0.5",
    "jsdoc-babel": "^0.5.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
